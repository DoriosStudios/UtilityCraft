          "anchor_from": "top_middle",
          "anchor_to": "top_middle",
          "offset": [10, 30],
          "collection_index": 3
        }
      },
      {
        "machinery@uc.item_display": {
          "anchor_from": "top_middle",
          "anchor_to": "top_middle",
          "offset": [10, 48],
          "collection_index": 2
        }
      },
      {

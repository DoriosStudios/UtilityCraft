          "$io_left_texture": "textures/blocks/generators/furnator/basic_off_west",
          "$io_front_texture": "textures/blocks/generators/furnator/basic_off_north",
          "$io_right_texture": "textures/blocks/generators/furnator/basic_off_east",
          "$io_bottom_texture": "textures/blocks/generators/furnator/basic_off_down",
          "$io_back_texture": "textures/blocks/generators/furnator/basic_off_south",
          "$io_item_top_index": 4,
          "$io_item_left_index": 5,
          "$io_item_front_index": 6,
          "$io_item_right_index": 7,
          "$io_item_bottom_index": 8,
          "$io_item_back_index": 9
        }
      },
      {
        "info_tab@uc.info_tab": {
          "$info_description": "ui.utilitycraft:info.furnator"
        }
      }

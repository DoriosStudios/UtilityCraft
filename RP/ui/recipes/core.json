{
    "namespace": "uc",
    "recipe_panel": {
        "type": "collection_panel",
        "anchor_from": "center",
        "anchor_to": "center",
        "size": [
            80,
            108
        ],
        "collection_name": "container_items",
        "$item_collection_name": "container_items",
        "$recipe_control_name|default": "",
        "bindings": [
            {
                "binding_type": "view",
                "source_control_name": "$recipe_control_name",
                "source_property_name": "#toggle_state",
                "target_property_name": "#visible",
                "resolve_sibling_scope": false
            }
        ]
    },
    "recipe_slot_overlay@uc.function_panel": {
        "type": "panel",
        "anchor_from": "center",
        "anchor_to": "center",
        "size": [
            16,
            16
        ],
        "$has_slot_item|default": true,
        "$has_slot_flipbook|default": false,
        "$slot_item_texture|default": "",
        "$slot_item_flipbook_texture|default": "",
        "$slot_item_flipbook_uv|default": "",
        "$slot_item_offset|default": [
            0,
            0
        ],
        "$slot_red_size|default": [
            16,
            16
        ],
        "$slot_red_offset|default": [
            0,
            0
        ],
        "controls": [
            {
                "recipe_item": {
                    "type": "image",
                    "visible": "$has_slot_item",
                    "texture": "$slot_item_texture",
                    "size": [
                        16,
                        16
                    ],
                    "offset": "$slot_item_offset",
                    "anchor_from": "top_middle",
                    "anchor_to": "top_middle",
                    "layer": 6
                }
            },
            {
                "recipe_item_flipbook": {
                    "type": "image",
                    "visible": "$has_slot_flipbook",
                    "texture": "$slot_item_flipbook_texture",
                    "size": [
                        16,
                        16
                    ],
                    "uv_size": [
                        16,
                        16
                    ],
                    "uv": "$slot_item_flipbook_uv",
                    "offset": "$slot_item_offset",
                    "anchor_from": "top_middle",
                    "anchor_to": "top_middle",
                    "layer": 6
                }
            },
            {
                "red_image": {
                    "type": "image",
                    "texture": "textures/ui/red_image",
                    "size": "$slot_red_size",
                    "offset": "$slot_red_offset",
                    "anchor_from": "top_middle",
                    "anchor_to": "top_middle",
                    "layer": 5
                }
            }
        ]
    },
